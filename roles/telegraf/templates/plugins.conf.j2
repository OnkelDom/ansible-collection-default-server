{{ ansible_managed | comment }}
{% macro toml_value(value) -%}
{%- if value is sameas true -%}true
{%- elif value is sameas false -%}false
{%- elif value is number -%}{{ value }}
{%- elif value is string -%}{{ value | to_json }}
{%- elif value is mapping -%}{ {{ toml_inline_table(value) }} }
{%- elif value is iterable and value is not string -%}[{{ value | map('to_json') | join(', ') }}]
{%- else -%}{{ value | to_json }}
{%- endif -%}
{%- endmacro %}
{% macro toml_inline_table(mapping) -%}
{%- for key, value in mapping.items() -%}
{{ key }} = {{ toml_value(value) }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
{%- endmacro %}

{% macro render_section(section) -%}
[[{{ section.plugin_type | default(item.plugin_type | default('inputs')) }}.{{ section.type | default(item.type) }}]]
{% for key, value in (section.config | default(item.config | default({}))).items() %}
{{ key }} = {{ toml_value(value) }}
{% endfor %}
{%- endmacro %}

{% if item.content is defined %}
{{ item.content | trim }}
{% elif item.sections is defined %}
{% for section in item.sections %}
{{ render_section(section) }}

{% endfor %}
{% else %}
{{ render_section(item) }}
{% endif %}
