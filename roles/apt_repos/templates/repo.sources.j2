Types: {{ item.types | default(['deb']) | join(' ') }}
URIs: {{ item.uris | default([item.uri]) | join(' ') }}
Suites: {{ item.suites | default([item.suite]) | join(' ') }}
{% if item.components is defined %}
Components: {{ item.components | join(' ') }}
{% endif %}
{% if item.architectures is defined %}
Architectures: {{ item.architectures | join(' ') }}
{% endif %}
{% if item.by_hash is defined %}
By-Hash: {{ item.by_hash }}
{% endif %}
{% if item.allow_insecure is defined %}
Allow-Insecure: {{ item.allow_insecure | ternary('yes', 'no') }}
{% endif %}
{% if item.allow_weak is defined %}
Allow-Weak: {{ item.allow_weak | ternary('yes', 'no') }}
{% endif %}
{% if item.check_valid_until is defined %}
Check-Valid-Until: {{ item.check_valid_until | ternary('yes', 'no') }}
{% endif %}
{% if item.enabled is defined %}
Enabled: {{ item.enabled | ternary('yes', 'no') }}
{% endif %}
{% if item.trusted is defined %}
Trusted: {{ item.trusted | ternary('yes', 'no') }}
{% endif %}
{% if item.signed_by is defined %}
Signed-By: {{ item.signed_by }}
{% elif apt_repos_manage_keys and (item.key_url is defined or item.key_content is defined or item.key_path is defined) %}
Signed-By: {{ item.key_path | default(apt_repos_keyring_directory ~ '/' ~ item.name ~ '.asc') }}
{% endif %}
