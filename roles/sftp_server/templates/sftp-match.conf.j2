# Managed by Ansible

Match Group {{ sftp_server_group }}
    ChrootDirectory {{ sftp_server_base_path }}/%u
    ForceCommand internal-sftp{% if sftp_server_internal_sftp_options | length > 0 %} {{ sftp_server_internal_sftp_options | join(' ') }}{% endif %}
    PasswordAuthentication {{ 'yes' if sftp_server_allow_password_auth else 'no' }}
    PubkeyAuthentication {{ 'yes' if sftp_server_allow_public_key_auth else 'no' }}
    PermitTunnel no
    AllowTcpForwarding no
    X11Forwarding no
    PermitTTY no
