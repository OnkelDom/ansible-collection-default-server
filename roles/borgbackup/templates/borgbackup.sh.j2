#!/bin/bash

set -euo pipefail

BORG_REPO="{{ borgbackup_repository }}"
BORG_PASSPHRASE="{{ borgbackup_encryption_passphrase }}"
ARCHIVE_NAME="{{ inventory_hostname }}-{{ borgbackup_archive_name }}"

export BORG_PASSPHRASE

borg create --verbose --stats --progress \
    "${BORG_REPO}::${ARCHIVE_NAME}" \
{% for source_path in borgbackup_source_paths %}
    {{ source_path }}{{ ' \\' if not loop.last else '' }}
{% endfor %}

borg prune --list "${BORG_REPO}" \
    --keep-daily={{ borgbackup_keep_daily }} \
    --keep-weekly={{ borgbackup_keep_weekly }} \
    --keep-monthly={{ borgbackup_keep_monthly }}

unset BORG_PASSPHRASE
